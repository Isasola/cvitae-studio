# Copy this file to .env.local and fill in values
# Add these same vars in Netlify → Site settings → Environment variables

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Confirmed public production origin, without a trailing slash.
# Leave empty until the definitive domain is confirmed; canonical and sitemap are omitted.
VITE_SITE_URL=
